# DeGate Multi-Market Intel — 环境变量模板
# 用法：复制本文件为 `.env` 并填入真实 key。`.env` 已在 `.gitignore`，不会入库。

# 必填：Reddit OAuth（从 https://www.reddit.com/prefs/apps 创建 script/web app）
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# 必填：用于规范化 User-Agent，避免 Reddit 侧把你当匿名脚本
REDDIT_USERNAME=your_reddit_username

# 可选：自定义 User-Agent 里的 app 标识
REDDIT_APP_NAME=degate-multi-intel
REDDIT_APP_VERSION=2.1

# 必填：xAI API key（从 https://console.x.ai 获取，以 xai- 开头）
XAI_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 可选：模型选择
# grok-3-latest → 便宜，日报够用
# grok-4-latest → 更强推理，贵约 5-10x
XAI_MODEL=grok-3-latest

# 可选：每条 query 最多返回的 tweet 数
# 20 → 月成本约 $30/市场
# 25 → 月成本约 $38/市场（默认）
# 30 → 月成本约 $45/市场
XAI_MAX_SEARCH_RESULTS=25

# 可选：上游方法仓库地址。若上游为私有仓库，建议填 SSH 地址：
# ITALY_INTEL_REPO_URL=git@github.com:RickyShiJs/italy_intel.git
ITALY_INTEL_REPO_URL=https://github.com/RickyShiJs/italy_intel.git
